{
  "name": "lnkbrd",
  "version": "1.0.0",
  "description": "Link Bird is an open-source API-first URL shortener",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/main.js",
    "lint": "prettier --write --config prettier.config.js --list-different src/**/*.ts",
    "start": "node ./dist/main.js",
    "test": "tsc && jest --coverage --testPathPatterns ./dist/.*\\.test\\.js$"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/view": "^11.1.1",
    "axios": "^1.15.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
    "ip3country": "^5.0.0",
    "isbot": "^5.1.39",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "qrcode": "^1.5.4",
    "qs": "^6.15.1",
    "ua-parser-js": "^2.0.9"
  }
}
